# ─── Auth.js v5 ───────────────────────────────────────────────────────────────
# Random secret used to sign/encrypt Auth.js session tokens.
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Full public URL of this app (used by Auth.js for callbacks).
# Example: http://localhost:3000 in dev, https://yourdomain.com in prod.
AUTH_URL=

# ─── AWS Core ─────────────────────────────────────────────────────────────────
# AWS region where all resources (DynamoDB, S3, SES, Cognito) are deployed.
AWS_REGION=

# IAM credentials for server-side AWS SDK calls.
# In production, prefer IAM roles attached to the compute resource instead.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ─── Amazon Cognito ───────────────────────────────────────────────────────────
# The ID of your Cognito User Pool (e.g. us-east-1_xxxxxxxxx).
COGNITO_USER_POOL_ID=

# The App Client ID created inside the User Pool.
COGNITO_CLIENT_ID=

# The App Client Secret (only present if "Generate client secret" was enabled).
COGNITO_CLIENT_SECRET=

# OIDC issuer URL for the User Pool.
# Format: https://cognito-idp.<region>.amazonaws.com/<user-pool-id>
COGNITO_ISSUER=

# ─── DynamoDB ─────────────────────────────────────────────────────────────────
# Name of the primary DynamoDB table used by HIPAApotamus.
DYNAMODB_TABLE_NAME=

# ─── S3 ───────────────────────────────────────────────────────────────────────
# S3 bucket where signed BAA documents and audit packets are stored.
S3_BUCKET_NAME=

# ─── Amazon SES ───────────────────────────────────────────────────────────────
# Verified sender email address used by SES for outbound notifications.
SES_FROM_EMAIL=

# ─── OpenAI ───────────────────────────────────────────────────────────────────
# API key for OpenAI — used by the AI audit-packet generation agent.
OPENAI_API_KEY=

# ─── ElevenLabs ───────────────────────────────────────────────────────────────
# API key for ElevenLabs text-to-speech (used in voice notification features).
ELEVENLABS_API_KEY=

# ID of the ElevenLabs voice to use for generated audio.
ELEVENLABS_VOICE_ID=

# ─── Public runtime config (safe to expose to the browser) ────────────────────
# Canonical public URL of the app — used for client-side link generation.
NEXT_PUBLIC_APP_URL=

# Display name shown in the UI and emails.
NEXT_PUBLIC_APP_NAME=HIPAApotamus
